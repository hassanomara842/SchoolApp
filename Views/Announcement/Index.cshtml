@model IEnumerable<SchoolApp.Models.Announcement>
@{
    ViewData["Title"] = "Manage Announcements";
}

<div class="container mt-4 mb-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold text-info"><i class="fa-solid fa-bullhorn me-2"></i> Manage Announcements & Offers</h2>
        <a asp-action="Create" class="btn btn-premium"><i class="fa-solid fa-plus me-1"></i> Add New</a>
    </div>

    <div class="glass-card p-4">
        <div class="table-responsive">
            <table class="table table-hover table-borderless align-middle text-white mb-0" style="background: transparent;">
                <thead class="bg-dark bg-opacity-50">
                    <tr>
                        <th class="py-3 px-4">Image</th>
                        <th class="py-3 px-4">Title</th>
                        <th class="py-3 px-4">Date</th>
                        <th class="py-3 px-4 text-center">Status</th>
                        <th class="py-3 px-4 text-end">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td class="py-3 px-4">
                                <img src="@item.ImageUrl" class="rounded object-fit-cover shadow-sm" width="60" height="60" alt="Offer Image" />
                            </td>
                            <td class="py-3 px-4 fw-bold">@item.Title</td>
                            <td class="py-3 px-4 text-muted">@item.CreatedAt.ToString("MMM dd, yyyy")</td>
                            <td class="py-3 px-4 text-center">
                                @if (item.IsActive)
                                {
                                    <span class="badge bg-success text-white px-3 py-2 rounded-pill"><i class="fa-solid fa-check-circle me-1"></i> Active</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary text-white px-3 py-2 rounded-pill"><i class="fa-solid fa-times-circle me-1"></i> Inactive</span>
                                }
                            </td>
                            <td class="py-3 px-4 text-end">
                                <div class="btn-group shadow-sm">
                                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-info"><i class="fa-solid fa-edit"></i></a>
                                    <form asp-action="Delete" asp-route-id="@item.Id" method="post" class="d-inline" onsubmit="return confirm('Are you sure you want to delete this announcement?');">
                                        <button type="submit" class="btn btn-sm btn-outline-danger"><i class="fa-solid fa-trash"></i></button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    }
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="5" class="text-center py-5 text-muted">
                                <i class="fa-solid fa-folder-open fs-1 mb-3"></i>
                                <h5>No announcements found.</h5>
                                <p>Click "Add New" to create your first offer or news item.</p>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
