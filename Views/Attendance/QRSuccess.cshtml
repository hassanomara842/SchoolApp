@{
    ViewData["Title"] = "Attendance Registered";
}

<div class="container mt-5 mb-5 text-center">
    <div class="card glass-panel border-0 rounded-4 shadow-lg p-5 mx-auto" style="max-width: 500px;">
        <div class="rounded-circle bg-success bg-opacity-10 d-inline-flex p-4 mx-auto mb-4">
            <i class="fa-solid fa-circle-check fs-1 text-success"></i>
        </div>
        
        <h2 class="text-white fw-bold mb-3">Attendance Registered!</h2>
        <p class="text-muted mb-4">You have successfully been marked as present for this course. You can now close this window or return to your dashboard.</p>
        
        <div>
            <a href="/" class="btn btn-primary rounded-pill px-5 py-2">Go to Dashboard</a>
        </div>
    </div>
</div>
