@model SchoolApp.Models.TakeAttendanceViewModel

@{
    ViewData["Title"] = "Take Attendance";
}

<div class="container py-5">
    <div class="d-flex justify-content-between align-items-center mb-4 mt-4">
        <div>
            <h1 class="display-6 fw-bold mb-0"><i class="fa-solid fa-clipboard-user text-primary me-2"></i> Attendance</h1>
            <p class="text-muted mb-0">Course: <span class="fw-bold text-light">@Model.CourseName</span> | Date: @Model.Date.ToString("MMMM dd, yyyy")</p>
        </div>
        <div class="d-flex gap-2">
            <a href="/Attendance/GenerateQR?courseId=@Model.CourseId" class="btn btn-warning rounded-pill px-4 shadow-sm" target="_blank">
                <i class="fa-solid fa-qrcode me-2"></i> Smart QR
            </a>
            <a href="/Attendance/Export?courseId=@Model.CourseId" class="btn btn-outline-success rounded-pill px-4 shadow-sm">
                <i class="fa-solid fa-file-excel me-2"></i> Export Report
            </a>
        </div>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show">
            <i class="fa-solid fa-check-circle me-2"></i> @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="card glass-card border-0 shadow-lg">
        <div class="card-body p-4">
            <form asp-action="Take" method="post">
                <input type="hidden" asp-for="CourseId" />
                <input type="hidden" asp-for="Date" />
                <input type="hidden" asp-for="CourseName" />

                <div class="table-responsive">
                    <table class="table text-white border-secondary table-hover align-middle">
                        <thead class="table-dark">
                            <tr>
                                <th>Student Name</th>
                                <th class="text-center">Present?</th>
                                <th>Remarks</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (Model.Records != null && Model.Records.Any())
                            {
                                @for (int i = 0; i < Model.Records.Count; i++)
                                {
                                    <tr>
                                        <td class="fw-bold">
                                            @Model.Records[i].TraineeName
                                            <input type="hidden" asp-for="Records[i].TraineeId" />
                                            <input type="hidden" asp-for="Records[i].TraineeName" />
                                        </td>
                                        <td class="text-center">
                                            <div class="form-check form-switch d-flex justify-content-center">
                                                <input class="form-check-input" type="checkbox" role="switch" asp-for="Records[i].IsPresent" style="transform: scale(1.5);">
                                            </div>
                                        </td>
                                        <td>
                                            <input type="text" asp-for="Records[i].Remarks" class="form-control bg-dark text-light border-secondary" placeholder="Optional remarks..." />
                                        </td>
                                    </tr>
                                }
                            }
                            else
                            {
                                <tr>
                                    <td colspan="3" class="text-center py-4 text-muted">
                                        <i class="fa-solid fa-users-slash display-4 mb-3 opacity-50"></i>
                                        <p>No students found for this course's department.</p>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>

                @if (Model.Records != null && Model.Records.Any())
                {
                    <div class="d-flex justify-content-between align-items-center mt-4">
                        <a asp-action="Export" asp-route-courseId="@Model.CourseId" class="btn btn-outline-success">
                            <i class="fa-solid fa-file-excel me-2"></i> Export to Excel
                        </a>
                        <button type="submit" class="btn btn-premium px-5">
                            <i class="fa-solid fa-floppy-disk me-2"></i> Save Attendance
                        </button>
                    </div>
                }
            </form>
        </div>
    </div>
</div>
