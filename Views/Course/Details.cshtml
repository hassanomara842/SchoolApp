@model SchoolApp.Models.Course

@{
    ViewData["Title"] = "Course Details";
}

<div class="container py-5">
    <div class="row mb-4">
        <div class="col">
            <h2 class="display-6 fw-bold text-gradient mb-3">@Model.Name</h2>
            <div class="d-flex gap-3">
                <span class="badge badge-custom"><i class="fa-solid fa-building me-1"></i> @Model.Department?.Name</span>
                <span class="badge badge-custom"><i class="fa-solid fa-clock me-1"></i> @Model.Hrs Hours</span>
                <span class="badge badge-custom"><i class="fa-solid fa-star me-1"></i> @Model.Degree Points (Min: @Model.MinDegree)</span>
            </div>
        </div>
        <div class="col-auto">
            @if (User.IsInRole("Trainee") && ViewBag.IsEnrolled != null && !(bool)ViewBag.IsEnrolled)
            {
                <a href="/Course/Checkout/@Model.Id" class="btn btn-success rounded-pill px-4 me-2">
                    <i class="fa-solid fa-cart-shopping me-2"></i> Buy Course ($@Model.Price)
                </a>
            }
            <a href="/Course/Discussion/@Model.Id" class="btn btn-warning rounded-pill px-4 me-2">
                <i class="fa-solid fa-comments me-2"></i> Join Discussion
            </a>
            <a asp-action="Index" class="btn btn-outline-light rounded-pill px-4">Back to List</a>
        </div>
    </div>

    <!-- Course Materials Section -->
    @if (User.IsInRole("Admin") || User.IsInRole("Instructor") || (User.IsInRole("Trainee") && ViewBag.IsEnrolled != null && (bool)ViewBag.IsEnrolled))
    {
        <div class="card glass-card border-0 shadow-lg mb-4">
        <div class="card-body p-4">
            <div class="d-flex justify-content-between align-items-center mb-4 border-bottom border-secondary pb-3">
                <h4 class="fw-bold mb-0">Course Materials</h4>
                @if (User.IsInRole("Admin") || User.IsInRole("Instructor"))
                {
                    <button type="button" class="btn btn-premium btn-sm" data-bs-toggle="collapse" data-bs-target="#uploadForm">
                        <i class="fa-solid fa-cloud-arrow-up me-1"></i> Upload Material
                    </button>
                }
            </div>

            @if (TempData["SuccessMessage"] != null)
            {
                <div class="alert alert-success alert-dismissible fade show">
                    <i class="fa-solid fa-check-circle me-2"></i> @TempData["SuccessMessage"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
            }
            @if (TempData["ErrorMessage"] != null)
            {
                <div class="alert alert-danger alert-dismissible fade show">
                    <i class="fa-solid fa-circle-exclamation me-2"></i> @TempData["ErrorMessage"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
            }

            @if (User.IsInRole("Admin") || User.IsInRole("Instructor"))
            {
                <div class="collapse mb-4" id="uploadForm">
                    <div class="card border-secondary bg-transparent">
                        <div class="card-body">
                            <form asp-controller="CourseMaterial" asp-action="Upload" method="post" enctype="multipart/form-data" class="d-flex align-items-center gap-3">
                                <input type="hidden" name="courseId" value="@Model.Id" />
                                <input type="file" name="file" class="form-control bg-dark text-light border-secondary" required />
                                <button type="submit" class="btn btn-success"><i class="fa-solid fa-upload me-1"></i> Upload</button>
                            </form>
                        </div>
                    </div>
                </div>
            }

            @if (Model.CourseMaterials != null && Model.CourseMaterials.Any())
            {
                <ul class="list-group list-group-flush bg-transparent">
                    @foreach (var material in Model.CourseMaterials.OrderByDescending(m => m.UploadDate))
                    {
                        <li class="list-group-item d-flex justify-content-between align-items-center p-3 bg-dark text-light border-secondary">
                            <div class="d-flex align-items-center">
                                @if (material.IsVideo && !string.IsNullOrEmpty(material.VideoUrl))
                                {
                                    <i class="fa-solid fa-circle-play text-danger fs-3 me-3"></i>
                                    <div>
                                        <h6 class="mb-0 fw-bold">@material.Title</h6>
                                        <small class="text-muted">Video Lecture</small>
                                    </div>
                                }
                                else
                                {
                                    <i class="fa-solid fa-file-pdf text-danger fs-3 me-3"></i>
                                    <div>
                                        <h6 class="mb-0 fw-bold">@material.Title</h6>
                                        <small class="text-muted">@material.UploadDate.ToString("MMM dd, yyyy")</small>
                                    </div>
                                }
                            </div>
                            <div class="d-flex gap-2">
                                @if (material.IsVideo && !string.IsNullOrEmpty(material.VideoUrl))
                                {
                                    <a href="@material.VideoUrl" target="_blank" class="btn btn-sm btn-outline-danger rounded-pill px-3">
                                        <i class="fa-solid fa-play me-1"></i> Watch
                                    </a>
                                }
                                else
                                {
                                    <a asp-controller="CourseMaterial" asp-action="Download" asp-route-id="@material.Id" class="btn btn-sm btn-outline-primary rounded-pill px-3">
                                        <i class="fa-solid fa-download me-1"></i> Download
                                    </a>
                                }
                                
                                @if (User.IsInRole("Admin") || User.IsInRole("Instructor"))
                                {
                                    <form asp-controller="CourseMaterial" asp-action="Delete" asp-route-id="@material.Id" method="post" class="d-inline">
                                        <button type="button" class="btn btn-outline-danger btn-sm px-3" onclick="confirmDelete(this.form)">
                                            <i class="fa-solid fa-trash me-1"></i>
                                        </button>
                                    </form>
                                }
                            </div>
                        </li>
                    }
                </ul>
            }
            else
            {
                <div class="text-center text-muted py-5">
                    <i class="fa-solid fa-folder-open display-4 mb-3 opacity-50"></i>
                    <p>No materials have been uploaded for this course yet.</p>
                </div>
            }
        </div>
    </div>
    }
</div>

<style>
    .material-card {
        transition: transform 0.3s ease, box-shadow 0.3s ease;
    }
    .material-card:hover {
        transform: translateY(-5px);
        box-shadow: 0 10px 20px rgba(0,0,0,0.3);
        border-color: rgba(99, 102, 241, 0.5) !important;
    }
</style>
