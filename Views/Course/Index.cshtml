@model IEnumerable<SchoolApp.Models.Course>

@{
    ViewData["Title"] = "Courses";
}

<div class="d-flex justify-content-between align-items-center mb-4 mt-4">
    <h1 class="display-5 fw-bold mb-0">Courses</h1>
    @if (User.IsInRole("Admin"))
    {
        <a asp-action="Create" class="btn btn-premium"><i class="fa-solid fa-plus me-2"></i>Add Course</a>
    }
</div>

<div class="glass-card p-4">
    <table class="table text-white border-secondary mb-0 table-datatable">
        <thead>
            <tr>
                <th>@Html.DisplayNameFor(model => model.Name)</th>
                <th>@Html.DisplayNameFor(model => model.Degree)</th>
                <th>Min Degree</th>
                <th>Hours</th>
                <th>Department</th>
                <th class="text-end">Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model) {
                <tr>
                    <td class="align-middle fw-bold">@item.Name</td>
                    <td class="align-middle text-success">@item.Degree</td>
                    <td class="align-middle text-warning">@item.MinDegree</td>
                    <td class="align-middle">@item.Hrs <small class="text-muted">hrs</small></td>
                    <td class="align-middle">@item.Department?.Name</td>
                    <td class="text-end">
                        <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-outline-info me-1"><i class="fa-solid fa-folder-open"></i> Materials</a>
                        @if (User.IsInRole("Admin") || User.IsInRole("Instructor"))
                        {
                            <a asp-controller="Attendance" asp-action="Take" asp-route-courseId="@item.Id" class="btn btn-sm btn-outline-warning me-1"><i class="fa-solid fa-clipboard-user"></i> Attendance</a>
                        }
                        @if (User.IsInRole("Admin"))
                        {
                            <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-light me-1"><i class="fa-solid fa-pen-to-square"></i> Edit</a>
                            <form asp-action="Delete" asp-route-id="@item.Id" method="post" class="d-inline">
                                <button type="button" class="btn btn-sm btn-outline-danger" onclick="confirmDelete(this.form)"><i class="fa-solid fa-trash"></i> Delete</button>
                            </form>
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
