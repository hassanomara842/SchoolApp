@model SchoolApp.Models.Department

@{
    ViewData["Title"] = "Create Department";
}

<div class="d-flex justify-content-between align-items-center mb-4 mt-4">
    <h1 class="display-5 fw-bold mb-0">Add New Department</h1>
</div>

<div class="row justify-content-center">
    <div class="col-md-6">
        <div class="glass-card p-4">
            <form asp-action="Create">
                <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                
                <div class="mb-3">
                    <label asp-for="Name" class="form-label fw-bold"></label>
                    <input asp-for="Name" class="form-control bg-transparent text-white border-secondary" />
                    <span asp-validation-for="Name" class="text-danger"></span>
                </div>

                <div class="mb-4">
                    <label asp-for="Manager" class="form-label fw-bold"></label>
                    <input asp-for="Manager" class="form-control bg-transparent text-white border-secondary" />
                    <span asp-validation-for="Manager" class="text-danger"></span>
                </div>

                <div class="d-flex justify-content-between">
                    <a asp-action="Index" class="btn btn-outline-light px-4">Back to List</a>
                    <button type="submit" class="btn btn-premium px-5"><i class="fa-solid fa-plus"></i> Create</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
