@model SchoolApp.Models.Quiz

@{
    ViewData["Title"] = "Quiz Details";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2><i class="fa-solid fa-clipboard-question text-primary me-2"></i> @Model.Title</h2>
        <div>
            <a asp-action="Index" class="btn btn-outline-secondary rounded-pill px-4"><i class="fa-solid fa-arrow-left me-1"></i> Back</a>
        </div>
    </div>
    
    <div class="card glass-card mb-4 border-0">
        <div class="card-body">
            <h5 class="text-light opacity-75 mb-3"><i class="fa-solid fa-book-open me-2 text-info"></i> Course: @Model.Course?.Name</h5>
            <p class="mb-2"><i class="fa-solid fa-stopwatch me-2 text-warning"></i> Duration: @Model.DurationMinutes Minutes</p>
            <p class="mb-0"><i class="fa-regular fa-calendar me-2 text-success"></i> Created: @Model.CreatedAt.ToString("MMM dd, yyyy")</p>
        </div>
    </div>

    <div class="mt-4">
        <h4 class="mb-3"><i class="fa-solid fa-list-check text-primary me-2"></i> Questions</h4>
        @if (Model.Questions != null && Model.Questions.Any())
        {
            var i = 1;
            foreach (var q in Model.Questions)
            {
                <div class="card glass-card mb-3 border-0">
                    <div class="card-body">
                        <h5 class="text-white">@i. @q.Text <span class="badge badge-custom float-end">@q.Points Points</span></h5>
                        <ul class="list-group list-group-flush mt-3 rounded-3" style="background: transparent;">
                            @foreach (var opt in q.Options)
                            {
                                <li class="list-group-item text-white @(opt.IsCorrect ? "bg-success bg-opacity-25 border-success" : "bg-transparent border-secondary border-opacity-25")">
                                    @if(opt.IsCorrect)
                                    {
                                        <i class="fa-solid fa-check text-success me-2"></i>
                                    }
                                    else
                                    {
                                        <i class="fa-regular fa-circle me-2 opacity-50"></i>
                                    }
                                    @opt.Text
                                </li>
                            }
                        </ul>
                    </div>
                </div>
                i++;
            }
        }
        else
        {
            <div class="alert alert-info glass-card text-white border-0 text-center py-4">
                <i class="fa-solid fa-circle-info fs-4 mb-2"></i><br />
                No questions added to this quiz yet.
            </div>
        }
    </div>
</div>
