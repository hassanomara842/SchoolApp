@using Microsoft.AspNetCore.Identity
@using Microsoft.AspNetCore.Mvc.Localization
@inject IViewLocalizer Localizer
@inject UserManager<SchoolApp.Models.ApplicationUser> UserManager
@inject AppDbContext DbContext
@{
    var isRTL = System.Globalization.CultureInfo.CurrentUICulture.TextInfo.IsRightToLeft;
    var lang = isRTL ? "ar" : "en";
    var dir = isRTL ? "rtl" : "ltr";
}
<!DOCTYPE html>
<html lang="@lang" dir="@dir" data-bs-theme="dark">
<head>
    <script>
        const savedTheme = localStorage.getItem('theme') || 'dark';
        document.documentElement.setAttribute('data-bs-theme', savedTheme);
    </script>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - SchoolApp</title>
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet">
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/SchoolApp.styles.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdn.datatables.net/1.13.6/css/dataTables.bootstrap5.min.css" />
    @if (isRTL)
    {
        <link href="https://fonts.googleapis.com/css2?family=Cairo:wght@400;600;800&display=swap" rel="stylesheet">
        <style>
            body { font-family: 'Cairo', 'Inter', sans-serif !important; }
        </style>
    }
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/sweetalert2@11/dist/sweetalert2.min.css" />
</head>
<body>
    <div class="wrapper">
        <!-- Sidebar -->
        @if (User.Identity?.IsAuthenticated == true)
        {
            <aside class="sidebar py-4 d-none d-md-flex">
                <div class="px-4 mb-4">
                    <a class="navbar-brand d-flex align-items-center gap-2 text-decoration-none" asp-area="" asp-controller="Home" asp-action="Index">
                        <i class="fa-solid fa-graduation-cap"></i> SchoolApp
                    </a>
                </div>
                <div class="nav flex-column w-100">
                    <div class="px-4 text-uppercase text-muted small fw-bold mb-2 mt-2">@Localizer["Management"]</div>
                    
                    @if (User.IsInRole("Admin"))
                    {
                        <a class="nav-link @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Admin" && ViewContext.RouteData.Values["Action"]?.ToString() == "Dashboard" ? "active" : "")" asp-controller="Admin" asp-action="Dashboard">
                            <i class="fa-solid fa-chart-pie"></i> @Localizer["Dashboard"]
                        </a>
                        <a class="nav-link @(Context.Request.Path.StartsWithSegments("/Department") ? "active" : "")" asp-controller="Department" asp-action="Index">
                            <i class="fa-solid fa-building me-2"></i> Departments
                        </a>
                        <a class="nav-link @(Context.Request.Path.StartsWithSegments("/Announcement") ? "active" : "")" asp-controller="Announcement" asp-action="Index">
                            <i class="fa-solid fa-bullhorn me-2 text-warning"></i> Announcements
                        </a>
                        <a class="nav-link @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Instructor" ? "active" : "")" asp-controller="Instructor" asp-action="Index">
                            <i class="fa-solid fa-chalkboard-user"></i> @Localizer["Instructors"]
                        </a>
                        <a class="nav-link @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Trainee" && ViewContext.RouteData.Values["Action"]?.ToString() == "Index" ? "active" : "")" asp-controller="Trainee" asp-action="Index">
                            <i class="fa-solid fa-users"></i> @Localizer["Trainees"]
                        </a>
                    }
                    
                    <a class="nav-link @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Quiz" ? "active" : "")" asp-controller="Quiz" asp-action="Index">
                        <i class="fa-solid fa-clipboard-question"></i> @Localizer["Quizzes"]
                    </a>

                    @if (User.IsInRole("Admin") || User.IsInRole("Instructor"))
                    {
                        <a class="nav-link @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Attendance" ? "active" : "")" asp-controller="Attendance" asp-action="Take" asp-route-courseId="1">
                            <i class="fa-solid fa-calendar-check"></i> @Localizer["Attendance"]
                        </a>
                    }

                    @if (User.IsInRole("Admin"))
                    {
                        <a class="nav-link @(Context.Request.Path.StartsWithSegments("/Trainee/Leaderboard") ? "active" : "")" asp-controller="Trainee" asp-action="Leaderboard">
                            <i class="fa-solid fa-trophy text-warning"></i> @Localizer["Leaderboard"]
                        </a>
                        <a class="nav-link @(Context.Request.Path.StartsWithSegments("/Home/Calendar") ? "active" : "")" asp-controller="Home" asp-action="Calendar">
                            <i class="fa-solid fa-calendar-days text-info"></i> @Localizer["Calendar"]
                        </a>
                    }
                </div>
            </aside>
        }

        <!-- Main Content -->
        <div class="main-content">
            <header>
                <nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-dark navbar-glass mb-4" style="z-index: 1050;">
                    <div class="container-fluid px-3">
                        <!-- Mobile Logo -->
                        <a class="navbar-brand d-flex align-items-center gap-2 d-md-none" asp-area="" asp-controller="Home" asp-action="Index">
                            <i class="fa-solid fa-graduation-cap"></i> SchoolApp
                        </a>
                        
                        <button class="navbar-toggler border-0" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                                aria-expanded="false" aria-label="Toggle navigation">
                            <span class="navbar-toggler-icon"></span>
                        </button>
                        
                        <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                            <ul class="navbar-nav me-auto mb-2 mb-lg-0">
                                <li class="nav-item">
                                    <a class="nav-link @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Home" && ViewContext.RouteData.Values["Action"]?.ToString() == "Index" ? "active text-white" : "")" asp-area="" asp-controller="Home" asp-action="Index">@Localizer["Home"]</a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Course" ? "active text-white" : "")" asp-area="" asp-controller="Course" asp-action="Index">@Localizer["Courses"]</a>
                                </li>
                            </ul>
                            
                            <div class="d-flex align-items-center">
                                @if (User.Identity?.IsAuthenticated == true)
                                {
                                    var user = await UserManager.GetUserAsync(User);
                                    var profilePic = string.IsNullOrEmpty(user?.ProfilePicturePath) ? $"https://api.dicebear.com/7.x/avataaars/svg?seed={user?.FullName}&backgroundColor=6366f1" : user.ProfilePicturePath;
                                    var unreadCount = DbContext.Notifications.Count(n => n.UserId == user.Id && !n.IsRead);
                                    var topNotifications = DbContext.Notifications.Where(n => n.UserId == user.Id).OrderByDescending(n => n.CreatedAt).Take(5).ToList();

                                    <div class="dropdown ms-3 me-3">
                                        <a class="btn btn-link text-light text-decoration-none position-relative" href="#" id="notificationDropdown" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                            <i class="fa-solid fa-bell fs-5"></i>
                                            @if (unreadCount > 0)
                                            {
                                                <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger" id="notificationBadge">
                                                    @unreadCount
                                                </span>
                                            }
                                        </a>
                                        <ul class="dropdown-menu dropdown-menu-end shadow-sm border-0 mt-2 p-0" aria-labelledby="notificationDropdown" style="width: 320px; max-height: 400px; overflow-y: auto;">
                                            <li class="p-3 border-bottom fw-bold text-center bg-light">@Localizer["Notifications"]</li>
                                            @if(topNotifications.Any())
                                            {
                                                foreach(var notif in topNotifications)
                                                {
                                                    <li class="p-3 border-bottom @(notif.IsRead ? "bg-white" : "bg-light")">
                                                        <small class="text-muted d-block mb-1">@notif.CreatedAt.ToLocalTime().ToString("g")</small>
                                                        <span class="text-dark" style="font-size: 0.9rem;">@notif.Message</span>
                                                    </li>
                                                }
                                            }
                                            else
                                            {
                                                <li class="p-3 text-center text-muted">No notifications yet.</li>
                                            }
                                        </ul>
                                    </div>

                                    <div class="dropdown">
                                        <a class="btn btn-outline-light dropdown-toggle d-flex align-items-center gap-2" href="#" role="button" id="userDropdown" data-bs-toggle="dropdown" aria-expanded="false">
                                            <img src="@profilePic" alt="Profile" class="rounded-circle object-fit-cover" width="30" height="30" />
                                            <span>@(user?.FullName ?? User.Identity.Name)</span>
                                        </a>
                                        <ul class="dropdown-menu dropdown-menu-end shadow-sm border-0 mt-2" aria-labelledby="userDropdown">
                                            <li><a class="dropdown-item" asp-controller="Account" asp-action="Profile"><i class="fa-solid fa-id-badge me-2"></i> @Localizer["My Profile"]</a></li>
                                            <li><hr class="dropdown-divider"></li>
                                            <li>
                                                <form asp-controller="Account" asp-action="Logout" method="post" class="d-inline">
                                                    <button type="submit" class="dropdown-item text-danger"><i class="fa-solid fa-arrow-right-from-bracket me-2"></i> @Localizer["Logout"]</button>
                                                </form>
                                            </li>
                                        </ul>
                                    </div>
                                }
                                else
                                {
                                    <a class="btn btn-outline-light me-2 px-4" asp-controller="Account" asp-action="Login">@Localizer["Login"]</a>
                                    <a class="btn btn-premium px-4" asp-controller="Account" asp-action="Register">@Localizer["Register"]</a>
                                }

                                <div class="dropdown ms-3">
                                    <a class="btn btn-link text-light text-decoration-none" href="#" id="themeToggleBtn" title="Toggle Theme">
                                        <i class="fa-solid fa-moon fs-5" id="themeIcon"></i>
                                    </a>
                                </div>
                                <div class="dropdown ms-1">
                                    <a class="btn btn-link text-light text-decoration-none dropdown-toggle" href="#" id="languageDropdown" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                        <i class="fa-solid fa-globe fs-5"></i>
                                    </a>
                                    <ul class="dropdown-menu dropdown-menu-end shadow-sm border-0 mt-2" aria-labelledby="languageDropdown">
                                        <li>
                                            <form asp-controller="Language" asp-action="SetLanguage" method="post" class="m-0">
                                                <input type="hidden" name="culture" value="en-US" />
                                                <input type="hidden" name="returnUrl" value="@Context.Request.Path" />
                                                <button type="submit" class="dropdown-item @(lang == "en" ? "active" : "")">English</button>
                                            </form>
                                        </li>
                                        <li>
                                            <form asp-controller="Language" asp-action="SetLanguage" method="post" class="m-0">
                                                <input type="hidden" name="culture" value="ar-EG" />
                                                <input type="hidden" name="returnUrl" value="@Context.Request.Path" />
                                                <button type="submit" class="dropdown-item @(lang == "ar" ? "active" : "")">العربية</button>
                                            </form>
                                        </li>
                                    </ul>
                                </div>
                            </div>
                        </div>
                    </div>
                </nav>
            </header>

            <div class="container-fluid px-md-4 flex-grow-1">
                <main role="main" class="pb-5">
                    @RenderBody()
                </main>
            </div>

            <footer class="footer text-muted border-top border-secondary mt-auto pt-3 pb-3">
                <div class="container-fluid px-4 text-center">
                    &copy; 2026 - SchoolApp <i class="fa-solid fa-bolt text-warning mx-1"></i> by Hassan Tech
                </div>
            </footer>
        </div>
    </div>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script src="https://cdn.datatables.net/1.13.6/js/jquery.dataTables.min.js"></script>
    <script src="https://cdn.datatables.net/1.13.6/js/dataTables.bootstrap5.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/7.0.12/signalr.min.js"></script>
    <script>
        const connection = new signalR.HubConnectionBuilder()
            .withUrl("/notificationHub")
            .build();

        connection.on("ReceiveNotification", function (message) {
            const Toast = Swal.mixin({
              toast: true,
              position: 'top-end',
              showConfirmButton: false,
              timer: 5000,
              timerProgressBar: true,
              didOpen: (toast) => {
                toast.addEventListener('mouseenter', Swal.stopTimer)
                toast.addEventListener('mouseleave', Swal.resumeTimer)
              }
            });

            Toast.fire({
              icon: 'info',
              title: message
            });
            
            // Play a small sound or highlight the bell
            let bell = document.querySelector('.fa-bell');
            if(bell) {
                bell.classList.add('text-warning');
                setTimeout(() => bell.classList.remove('text-warning'), 2000);
            }
        });

        connection.start().catch(function (err) {
            return console.error(err.toString());
        });

        // Theme Toggle Logic
        document.addEventListener('DOMContentLoaded', () => {
            const themeBtn = document.getElementById('themeToggleBtn');
            const themeIcon = document.getElementById('themeIcon');
            const htmlEl = document.documentElement;
            
            const updateIcon = (theme) => {
                if (theme === 'light') {
                    themeIcon.classList.remove('fa-moon');
                    themeIcon.classList.add('fa-sun');
                } else {
                    themeIcon.classList.remove('fa-sun');
                    themeIcon.classList.add('fa-moon');
                }
            };
            
            updateIcon(htmlEl.getAttribute('data-bs-theme'));

            themeBtn.addEventListener('click', (e) => {
                e.preventDefault();
                let currentTheme = htmlEl.getAttribute('data-bs-theme');
                let newTheme = currentTheme === 'dark' ? 'light' : 'dark';
                
                htmlEl.setAttribute('data-bs-theme', newTheme);
                localStorage.setItem('theme', newTheme);
                updateIcon(newTheme);
            });
        });
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
